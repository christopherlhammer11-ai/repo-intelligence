{
  "name": "repo-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop-first codebase Q&A with Ollama and LanceDB.",
  "author": {
    "name": "Christopher Hammer"
  },
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "desktop:dev": "concurrently -k \"npm run dev\" \"npm run electron:dev\"",
    "electron:dev": "wait-on http://127.0.0.1:3000 && DEV_SERVER_URL=http://127.0.0.1:3000 electron .",
    "electron:build:mac": "npm run build && electron-builder --mac dmg",
    "electron:build": "npm run build && electron-builder",
    "lint": "eslint",
    "test": "npm run lint && tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@lancedb/lancedb": "^0.27.2",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "ollama-ai-provider-v2": "^3.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.christopherhammer.repointelligence",
    "productName": "Repo Intelligence",
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "artifactName": "Repo-Intelligence.${ext}",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "contents": [
        {
          "x": 140,
          "y": 220
        },
        {
          "x": 400,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "icon": "build/icon.icns",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
